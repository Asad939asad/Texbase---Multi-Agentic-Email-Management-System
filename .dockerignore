# ── .dockerignore ────────────────────────────────────────────────
# Exclude everything that inflates image size or leaks secrets

# Large ML models (3.5 GB+)
**/local_qwen_model
**/local_qwen_model/

# Python virtual environments
qwen_env
qwen_env/
venv
.venv
**/qwen_env
**/.venv

# Node modules (reinstalled inside image)
node_modules
**/node_modules

# Secrets & env files
.env
*.env
backend/.env
frontend/.env

# Build artifacts & caches
dist
build
__pycache__
**/__pycache__
*.pyc

# Local databases & data files (mounted via volumes)
*.db
*.xlsx
chroma_db
chroma_db/

# OS & IDE
.DS_Store
**/.DS_Store
.git
.github

# Credentials
Google Credentials
Google Credentials/
client_secret_*.json

# Frontend (not served from this container)
frontend
frontend/
